# Copy to .env and fill in your values
# Never commit .env to git

# LLM providers (at least one required for RAG)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# AWS (for MLflow artifact store — can use LocalStack locally)
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_DEFAULT_REGION=us-east-1
MLFLOW_S3_ENDPOINT_URL=http://localstack:4566   # remove for real S3

# Retraining webhook (GitHub Actions, Airflow, etc.)
RETRAINING_WEBHOOK_URL=

# Override defaults if needed
REDIS_URL=redis://redis:6379/0
POSTGRES_DSN=postgresql://mlplatform:mlplatform@postgres:5432/features
MLFLOW_TRACKING_URI=http://mlflow:5000
CHROMA_HOST=chromadb
CHROMA_PORT=8000
